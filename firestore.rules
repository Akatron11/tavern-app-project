rules_version = '2';
// Tek kullanıcılı MVP (Kemal). Tüm koleksiyonlar kimlik doğrulaması ile kilitli:
// oturum açmış kullanıcı okur/yazar, kimliksiz erişim reddedilir.
// Per-uid kapsam ve alan-bazlı şema doğrulaması v2'ye ertelendi (master plan §1.9).
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}